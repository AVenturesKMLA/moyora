# Copy to `.env` / hosting env for non-secret defaults or production.
# For MongoDB on your machine, use `.env.local` (see below).

# NextAuth Configuration
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=your_nextauth_secret_here

# PortOne V2 API (Sandbox)
PORTONE_API_KEY=your_portone_api_key_here
PORTONE_API_SECRET=your_portone_api_secret_here

# Optional: dev-only admin login on /login — copy config/dev-admin.env.example to config/dev-admin.env
#
# Local MongoDB: create `.env.local` in the project root (next to package.json) and set:
# MONGODB_URI=mongodb+srv://USER:PASSWORD@cluster.../?appName=...
#
# MongoDB 없이 로컬에서만 관리자 UI 미리보기 (개발 전용, 기본값 true — 끄려면 false):
# DEV_ADMIN_NO_DB=false
# DEV_ADMIN_SYNTHETIC_EMAIL=dev-admin@local.test
# 그리고 기존처럼 DEV_ADMIN_LOGIN_KEY / NEXT_PUBLIC_DEV_ADMIN_LOGIN_KEY
